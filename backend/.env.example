# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=sb_secret_YOUR_SERVICE_KEY_HERE

# Server Configuration
PORT=5000
NODE_ENV=development

# OpenRouter API Configuration (for AI event extraction)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# CORS Configuration
FRONTEND_URL=https://campus-flow-flax.vercel.app
# For local development: FRONTEND_URL=http://localhost:5173

# n8n Webhook
N8N_WEBHOOK_URL=https://muhammadnavas.app.n8n.cloud/webhook/reminder
