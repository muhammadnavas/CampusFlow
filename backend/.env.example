# ============================================
# Backend Environment Configuration (Example)
# ============================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES

# ============================================
# Supabase Configuration
# ============================================
# Get these from https://app.supabase.com
# 1. Create a new project
# 2. Go to Settings > API
# 3. Copy PROJECT_URL and Keys

# Your Supabase project URL
# Example: https://abcdefghijk.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (for client-side access)
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY_HERE

# Supabase Service Role Key (for backend access - KEEP PRIVATE!)
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=sb_secret_YOUR_SERVICE_KEY_HERE

# ============================================
# OpenRouter API Configuration
# ============================================
# For AI-powered event extraction from notices
# Get free $5 credits at https://openrouter.ai

# Your OpenRouter API Key
# Example: sk-or-v1-abc123def456...
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# Model to use for event extraction
# Options: openai/gpt-4o-mini, openai/gpt-4, openai/gpt-3.5-turbo
OPENROUTER_MODEL=openai/gpt-4o-mini

# ============================================
# Server Configuration
# ============================================
# Port to run the backend server on
PORT=5000

# Environment (development|production)
NODE_ENV=development

# ============================================
# CORS Configuration
# ============================================
# Frontend URL (for cross-origin requests)
# LOCAL: http://localhost:5173
# PRODUCTION: https://campus-flow-flax.vercel.app
FRONTEND_URL=http://localhost:5173

# ============================================
# n8n Automation Webhook
# ============================================
# For WhatsApp reminders and event automation
# Get from your n8n workflow webhook trigger
# Example: https://your-n8n.cloud/webhook/reminder
N8N_WEBHOOK_URL=https://muhammadnavas.app.n8n.cloud/webhook/reminder
