# Frontend Environment Configuration Example

# API Base URL (Backend)
# For local development: VITE_API_URL=http://localhost:5000/api
# For production: VITE_API_URL=https://campusflow-qas5.onrender.com/api
VITE_API_URL=https://campusflow-qas5.onrender.com/api

# n8n Webhook URL for event processing
VITE_N8N_WEBHOOK_URL=https://muhammadnavas.app.n8n.cloud/webhook/reminder
# For local testing: VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/reminder

# Gemini AI for text parsing (Extract event details from college notices)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Get your API key from: https://ai.google.dev/
# Instructions:
# 1. Go to https://ai.google.dev/
# 2. Click "Get API Key"
# 3. Create a new API key in Google Cloud Console
# 4. Copy it here
